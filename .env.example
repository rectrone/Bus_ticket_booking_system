# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bus_booking"

# JWT Secrets
JWT_SECRET="your_jwt_secret_key_here_at_least_32_characters_long"
JWT_REFRESH_SECRET="your_refresh_token_secret_here_at_least_32_characters_long"
JWT_EXPIRY="7d"
JWT_REFRESH_EXPIRY="30d"

# Server
PORT=5000
NODE_ENV="development"

# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@busbooking.com"

# Payment (Mock for now)
PAYMENT_MOCK_MODE="true"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Seat Configuration
MAX_SEATS_PER_BOOKING=6

# Email Service
ENABLE_EMAIL_NOTIFICATIONS="true"
